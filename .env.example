# Optional local overrides for shell sessions.
# This file is safe to commit. Copy to .env only for your own machine.

# Root Makefile and smoke script
PYTHON=.venv/bin/python
MODEL=Qwen/Qwen2.5-0.5B-Instruct
INFERENCE_PORT=8000
GATEWAY_PORT=8080

# Inference service
INFERENCE_CONFIG_PATH=config.yaml
INFERENCE_SERVER_HOST=0.0.0.0
INFERENCE_SERVER_PORT=8000
INFERENCE_ENGINE_TYPE=mock
INFERENCE_ENGINE_MODEL_PATH=Qwen/Qwen2.5-0.5B-Instruct
INFERENCE_ENGINE_BASE_URL=
INFERENCE_ENGINE_API_KEY=

# AI gateway
GATEWAY_CONFIG_PATH=configs/config.yaml
GATEWAY_MODELS_PATH=configs/models.yaml
GATEWAY_SERVER_HOST=0.0.0.0
GATEWAY_SERVER_PORT=8080
AUTH_ENABLED=true
# Pydantic parses list env vars as JSON.
AUTH_API_KEYS='["sk-test-key-1"]'
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_REQUESTS_PER_MINUTE=60
GATEWAY_CACHE_ENABLED=false
GATEWAY_CACHE_TTL_SECONDS=60

# Finetune demo
FINETUNE_CONFIG_PATH=
FINETUNE_OUTPUT_DIR=./outputs
FINETUNE_DATA__TRAIN_FILE=./data/train.jsonl
